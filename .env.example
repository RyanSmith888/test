# Claude Gateway Configuration
# Copy to .env and modify as needed

# Server
PORT=8080

# Database
DB_PATH=gateway.db

# Admin key (auto-generated if empty)
ADMIN_KEY=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Upstream Claude API
UPSTREAM_URL=https://api.anthropic.com

# Pool defaults
DEFAULT_RPM=20           # Default RPM per account (20 recommended for anti-ban)
DEFAULT_MAX_CONCUR=5     # Default max concurrent requests per account
MAX_RETRY_ATTEMPTS=3

# Pool tuning
POOL_RELOAD_INTERVAL=2m
RPM_RESET_INTERVAL=60s
TOKEN_REFRESH_LEAD=30m

# Async log writer
LOG_CHANNEL_SIZE=8192
LOG_FLUSH_SIZE=200
LOG_FLUSH_INTERVAL=2s
